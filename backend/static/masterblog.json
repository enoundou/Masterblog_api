{
  "swagger": "2.0",
  "info": {
    "title": "Masterblog API",
    "version": "1.0.0"
  },
  "host": "localhost:5002",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "tags": [
    {
      "name": "Post",
      "description": "Post API - CRUD"
    }
  ],
  "paths": {
    "/api/posts": {
      "get": {
        "summary": "Returns all posts",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "type": "string",
            "required": false,
            "enum": [
              "title",
              "content",
              "author",
              "date"
            ]
          },
          {
            "name": "direction",
            "in": "query",
            "type": "string",
            "required": false,
            "enum": [
              "asc",
              "desc"
            ],
            "default": "asc"
          },
          {
            "name": "page",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 1
          },
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 10
          }
        ],
        "responses": {
          "200": {
            "description": "Posts returned successfully"
          }
        }
      },
      "post": {
        "summary": "Creates a new post",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "post",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PostInput"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Post created successfully"
          },
          "400": {
            "description": "Invalid post data"
          }
        }
      }
    },
    "/api/posts/{post_id}": {
      "get": {
        "summary": "Returns a post by id",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "404": {
            "description": "Post not found"
          }
        }
      },
      "put": {
        "summary": "Updates a post by id",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "name": "post",
            "in": "body",
            "schema": {
              "$ref": "#/definitions/PostUpdateInput"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post updated successfully"
          },
          "404": {
            "description": "Post not found"
          }
        }
      },
      "delete": {
        "summary": "Deletes a post by id",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Post deleted successfully"
          },
          "404": {
            "description": "Post not found"
          }
        }
      }
    },
    "/api/posts/search": {
      "get": {
        "summary": "Returns all matching posts",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Post"
        ],
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "type": "string",
            "required": false,
            "description": "Filter posts by title (partial match)"
          },
          {
            "name": "content",
            "in": "query",
            "type": "string",
            "required": false,
            "description": "Filter posts by content (partial match)"
          },
          {
            "name": "author",
            "in": "query",
            "type": "string",
            "required": false,
            "description": "Filter posts by author"
          },
          {
            "name": "date",
            "in": "query",
            "type": "string",
            "format": "date",
            "required": false,
            "description": "Filter posts by date"
          },
          {
            "name": "page",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 1
          },
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 10
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    }
  },
  "definitions": {
    "PostInput": {
      "type": "object",
      "required": [
        "title",
        "content",
        "author",
        "date"
      ],
      "properties": {
        "title": {
          "type": "string",
          "example": "Flask API"
        },
        "content": {
          "type": "string",
          "example": "Build APIs with Flask"
        },
        "author": {
          "type": "string",
          "example": "Alice"
        },
        "date": {
          "type": "string",
          "format": "date",
          "example": "2026-04-28"
        },
        "category": {
          "type": "string",
          "example": "Programming"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "python",
            "flask"
          ]
        },
        "comments": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "PostUpdateInput": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "example": "Flask API"
        },
        "content": {
          "type": "string",
          "example": "Build APIs with Flask"
        },
        "author": {
          "type": "string",
          "example": "Alice"
        },
        "date": {
          "type": "string",
          "format": "date",
          "example": "2026-04-28"
        },
        "category": {
          "type": "string",
          "example": "Programming"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "python",
            "flask"
          ]
        },
        "comments": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}